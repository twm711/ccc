# ─── Server ───
SERVER_PORT=8080

# ─── MySQL ───
MYSQL_ROOT_PASSWORD=ccc_root_pass
MYSQL_DATABASE=ccc
MYSQL_USER=ccc
MYSQL_PASSWORD=ccc_pass
DATABASE_DSN=ccc:ccc_pass@tcp(mysql:3306)/ccc?parseTime=true&charset=utf8mb4&collation=utf8mb4_0900_ai_ci

# ─── Redis ───
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-32
JWT_ISSUER=ccc-platform

# ─── Snowflake ───
SNOWFLAKE_NODE_ID=1

# ─── MinIO (S3-compatible) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=ccc-recordings
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ─── FreeSWITCH ESL ───
ESL_HOST=freeswitch
ESL_PORT=8021
ESL_PASSWORD=ClueCon

# ─── NATS ───
NATS_URL=nats://nats:4222

# ─── Kafka ───
KAFKA_BROKERS=kafka:9092

# ─── Aliyun (AI / SMS) ───
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_APP_KEY=

# ─── DashScope (通义千问 LLM) ───
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# ─── Frontend ───
VITE_API_BASE_URL=/api/v1

# ─── Prometheus ───
PROMETHEUS_ENABLED=true

# ─── Grafana ───
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
